---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Meet Seamus, your personal AI chef. Get real-time cooking guidance, recipes, meal planning, and culinary education — all by voice, in 30+ languages.',
  ogImage = '/logo.png',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#3E2C20" />
  <link rel="icon" type="image/png" href="/logo.png" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Eagle+Lake&family=Quicksand:wght@400;500;600;700&family=Georgia&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>
